{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "ignoreDeprecations": "6.0",
    "module": "es2020",
    "moduleDetection": "force",
    "noImplicitAny": true,
    "noEmit": true,
    "target": "es2020",
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "test/**/*.ts",
    "types/node-globals.d.ts"
  ]
}
