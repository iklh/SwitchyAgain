{
  "name": "@switchyagain/extension-runtime",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "dependencies": {
    "jsondiffpatch": "^0.7.6",
    "limiter": "^3.0.0",
    "@switchyagain/proxy-engine": "0.0.1"
  },
  "browser": {
    "@switchyagain/proxy-engine": "./build-ts/omega_pac_shim.js"
  },
  "scripts": {
    "build": "npm run build:ts && node ../../scripts/bundle-esbuild.mjs --entry=src/index.ts --outfile=index.js --format=cjs --platform=node --target=es2015 --external=buffer,jsondiffpatch,limiter,@switchyagain/proxy-engine && node ../../scripts/bundle-esbuild.mjs --entry=src/index.ts --outfile=omega_target.min.js --global-name=OmegaTarget --target=es2015 --minify",
    "build:ts": "tsc -p tsconfig.build.json",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "dev": "npm link @switchyagain/proxy-engine && npm link",
    "test": "npm run typecheck:test && TZ=UTC vitest run",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.json --noEmit && npm run typecheck:test"
  }
}
