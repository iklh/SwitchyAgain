{
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "module": "none",
    "noEmit": false,
    "noImplicitAny": true,
    "outDir": "build-ts/js",
    "rootDir": "src/js",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "target": "es2020"
  },
  "include": [
    "src/js/draw_omega.ts",
    "src/js/log_error.ts",
    "types/**/*.d.ts"
  ]
}
