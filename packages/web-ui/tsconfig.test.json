{
  "extends": "./tsconfig.react.json",
  "compilerOptions": {
    "allowJs": false,
    "ignoreDeprecations": "6.0",
    "module": "es2022",
    "moduleDetection": "force",
    "noEmit": true,
    "target": "es2022",
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "test/**/*.ts",
    "types/**/*.d.ts"
  ]
}
