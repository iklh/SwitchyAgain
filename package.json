{
  "name": "@switchyagain/workspace",
  "private": true,
  "workspaces": [
    "packages/proxy-engine",
    "packages/extension-runtime",
    "packages/web-ui",
    "apps/browser-extension"
  ],
  "scripts": {
    "build": "npm run build --workspace @switchyagain/browser-extension && npm run check:package-entrypoints",
    "build:pac": "npm run build --workspace @switchyagain/proxy-engine",
    "build:target": "npm run build --workspace @switchyagain/extension-runtime",
    "build:web": "npm run build --workspace @switchyagain/web-ui",
    "check:build-assumptions": "node scripts/generate-browser-entrypoints.mjs --check && node scripts/check-build-assumptions.mjs",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "check:po": "node scripts/check-po.mjs",
    "format": "prettier --write \"packages/web-ui/src/react/**/*.{ts,tsx,css}\" \"packages/web-ui/test/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/web-ui/src/react/**/*.{ts,tsx,css}\" \"packages/web-ui/test/**/*.{ts,tsx}\"",
    "generate:entrypoints": "node scripts/generate-browser-entrypoints.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package:dist": "node scripts/package-dist.mjs",
    "release": "npm run check:build-assumptions && npm run release --workspace @switchyagain/browser-extension && npm run check:package-entrypoints",
    "smoke": "npm run smoke:chromium",
    "smoke:chromium": "npm run build && npm run smoke:install:chromium && npm run smoke:ui:chromium && npm run smoke:extension:chromium",
    "smoke:extension": "npm run smoke:extension:chromium",
    "smoke:extension:chromium": "npx --yes --package playwright node scripts/smoke-extension-chromium.mjs",
    "smoke:extension:firefox": "npx --yes --package selenium-webdriver --package geckodriver node scripts/smoke-extension-firefox.mjs",
    "smoke:firefox": "npm run build && npm run smoke:install:firefox && npm run smoke:ui:firefox && npm run smoke:extension:firefox",
    "smoke:install": "npm run smoke:install:chromium",
    "smoke:install:chromium": "npx --yes --package playwright playwright install chromium",
    "smoke:install:firefox": "npx --yes --package playwright playwright install firefox",
    "smoke:ui": "npm run smoke:ui:chromium",
    "smoke:ui:chromium": "npx --yes --package playwright node scripts/smoke-ui.mjs chromium",
    "smoke:ui:firefox": "npx --yes --package playwright node scripts/smoke-ui.mjs firefox",
    "test": "npm run test --workspace @switchyagain/proxy-engine && npm run test --workspace @switchyagain/extension-runtime && npm run test --workspace @switchyagain/web-ui",
    "typecheck": "npm run check:build-assumptions && npm run typecheck --workspace @switchyagain/proxy-engine && npm run typecheck --workspace @switchyagain/extension-runtime && npm run typecheck --workspace @switchyagain/web-ui && npm run typecheck --workspace @switchyagain/browser-extension"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.2",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.23",
    "buffer": "^6.0.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.4",
    "process": "^0.11.10",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
