{
  "name": "@switchyagain/workspace",
  "private": true,
  "workspaces": [
    "packages/proxy-engine",
    "packages/extension-runtime",
    "packages/web-ui",
    "apps/browser-extension"
  ],
  "scripts": {
    "build": "npm run build --workspace @switchyagain/browser-extension",
    "build:pac": "npm run build --workspace @switchyagain/proxy-engine",
    "build:target": "npm run build --workspace @switchyagain/extension-runtime",
    "build:web": "npm run build --workspace @switchyagain/web-ui",
    "package:dist": "node scripts/package-dist.mjs",
    "release": "npm run release --workspace @switchyagain/browser-extension",
    "smoke": "npm run smoke:chromium",
    "smoke:chromium": "npm run build && npm run smoke:install:chromium && npm run smoke:ui:chromium && npm run smoke:extension:chromium",
    "smoke:extension": "npm run smoke:extension:chromium",
    "smoke:extension:chromium": "npx --yes --package playwright node scripts/smoke-extension-chromium.mjs",
    "smoke:extension:firefox": "npx --yes --package selenium-webdriver --package geckodriver node scripts/smoke-extension-firefox.mjs",
    "smoke:firefox": "npm run build && npm run smoke:install:firefox && npm run smoke:ui:firefox && npm run smoke:extension:firefox",
    "smoke:install": "npm run smoke:install:chromium",
    "smoke:install:chromium": "npx --yes --package playwright playwright install chromium",
    "smoke:install:firefox": "npx --yes --package playwright playwright install firefox",
    "smoke:ui": "npm run smoke:ui:chromium",
    "smoke:ui:chromium": "npx --yes --package playwright node scripts/smoke-ui.mjs chromium",
    "smoke:ui:firefox": "npx --yes --package playwright node scripts/smoke-ui.mjs firefox",
    "test": "npm run test --workspace @switchyagain/proxy-engine && npm run test --workspace @switchyagain/extension-runtime",
    "typecheck": "npm run typecheck --workspace @switchyagain/proxy-engine && npm run typecheck --workspace @switchyagain/extension-runtime && npm run typecheck --workspace @switchyagain/web-ui && npm run typecheck --workspace @switchyagain/browser-extension"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "archiver": "^8.0.0",
    "autoprefixer": "^10.4.23",
    "buffer": "^6.0.3",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.6",
    "process": "^0.11.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
