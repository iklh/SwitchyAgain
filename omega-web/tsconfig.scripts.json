{
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "module": "none",
    "noEmit": false,
    "noImplicitAny": false,
    "outDir": "src/js",
    "rootDir": "src/js",
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": false,
    "target": "es5"
  },
  "include": [
    "src/js/**/*.ts",
    "types/**/*.d.ts"
  ]
}
