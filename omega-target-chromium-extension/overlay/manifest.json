{
  "manifest_version": 3,
  "name": "__MSG_manifest_app_name__",
  "version": "1.1.16",
  "description": "__MSG_manifest_app_description__",
  "key": "",
  "icons": {
    "16": "img/icons/omega-action-16.png",
    "24": "img/icons/omega-action-24.png",
    "32": "img/icons/omega-action-32.png",
    "48": "img/icons/omega-48.png",
    "64": "img/icons/omega-64.png",
    "128": "img/icons/omega-128.png"
  },
  "default_locale": "en",
  "action": {
    "default_icon": {
      "16": "img/icons/omega-action-16.png",
      "19": "img/icons/omega-action-19.png",
      "24": "img/icons/omega-action-24.png",
      "32": "img/icons/omega-action-32.png"
    },
    "default_title": "__MSG_manifest_icon_default_title__",
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "service_worker.js",
    "scripts": [
      "js/mv3_compat.js",
      "js/log_error.js",
      "lib/FileSaver/FileSaver.min.js",
      "js/omega_debug.js",
      "js/background_preload.js",
      "js/omega_pac.min.js",
      "js/omega_target.min.js",
      "js/omega_target_chromium_extension.min.js",
      "img/icons/draw_omega.js",
      "js/background.js"
    ],
    "preferred_environment": ["document", "service_worker"]
  },
  "minimum_chrome_version": "121.0.0",
  "options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "browser_style": false,
    "open_in_tab": true
  },
  "permissions": [
    "proxy",
    "tabs",
    "alarms",
    "storage",
    "webRequest",
    "webRequestAuthProvider",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "<all_urls>"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+O"
      }
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "switchyagain@com.github.iklh",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
