{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "build-ts",
    "rootDir": "src",
    "sourceMap": false,
    "target": "es5"
  },
  "include": [
    "src/**/*.ts",
    "types/**/*.d.ts"
  ]
}
