{
  "name": "omega-pac",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "dependencies": {
    "ip-address": "^4.0.0",
    "tldjs": "^1.5.2"
  },
  "scripts": {
    "build": "npm run build:ts && node ../scripts/write-cjs-wrapper.mjs --module=./build-ts/index.js --outfile=index.js && node ../scripts/bundle-esbuild.mjs --entry=src/index.ts --outfile=omega_pac.min.js --global-name=OmegaPac --target=es2015 --minify",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "dev": "npm link",
    "test": "npm run build:ts && npm run build:test && TZ=Europe/London _mocha --reporter spec build-test/*.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  }
}
