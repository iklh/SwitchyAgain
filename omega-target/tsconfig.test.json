{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleDetection": "force",
    "noImplicitAny": true,
    "noEmit": false,
    "outDir": "build-test",
    "rootDir": "test",
    "sourceMap": false,
    "target": "es2015"
  },
  "include": [
    "test/**/*.ts",
    "types/test-globals.d.ts"
  ]
}
