{
  "name": "omega-target",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "dependencies": {
    "bluebird": "^2.3.2",
    "jsondiffpatch": "^0.1.8",
    "limiter": "^1.0.5",
    "omega-pac": "../omega-pac"
  },
  "browser": {
    "omega-pac": "./build-ts/omega_pac_shim.js"
  },
  "scripts": {
    "build": "npm run build:ts && node ../scripts/bundle-esbuild.mjs --entry=src/index.ts --outfile=index.js --format=cjs --platform=node --target=es2015 --external=bluebird,buffer,jsondiffpatch,limiter,omega-pac && node ../scripts/bundle-esbuild.mjs --entry=src/index.ts --outfile=omega_target.min.js --global-name=OmegaTarget --target=es2015 --minify",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json --noEmit && node ../scripts/build-test-files.mjs --test-dir=test --out-dir=build-test",
    "dev": "npm link omega-pac && npm link",
    "test": "npm run build:ts && npm run build:test && NODE_PATH=.. TZ=Europe/London _mocha --reporter spec build-test/*.js",
    "typecheck": "npm run build:ts && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  }
}
